PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Business Info ─────────────────────────────────────────────
BUSINESS_PHONE=+91 XXXXXXXXXX
BUSINESS_WHATSAPP=91XXXXXXXXXX        # No +, no spaces e.g. 919876543210
BUSINESS_EMAIL=hello@yourrestaurant.com
BUSINESS_EMAIL_ORDERS=orders@yourrestaurant.com
BUSINESS_ADDRESS=Your Full Street Address, City, PIN
BUSINESS_HOURS=Mon-Sun: 11:00 AM - 11:00 PM

# ── Vite Client (VITE_ prefix required — included in browser bundle) ──
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX
VITE_BUSINESS_PHONE=+91 XXXXXXXXXX
VITE_BUSINESS_EMAIL=hello@yourrestaurant.com
VITE_BUSINESS_ADDRESS=Your Full Street Address, City, PIN
VITE_BUSINESS_HOURS=Mon-Sun: 11:00 AM - 11:00 PM

# ── MongoDB Atlas ─────────────────────────────────────────────
# 1. Create free cluster at cloud.mongodb.com
# 2. Database Access → add user with read/write
# 3. Network Access → add your IP (or 0.0.0.0/0 for dev)
# 4. Connect → Drivers → copy URI, replace <password>
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tastevo?retryWrites=true&w=majority

# ── Email / SMTP (Nodemailer) ─────────────────────────────────
# Gmail setup:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to myaccount.google.com/apppasswords
#   3. Create an App Password → use it as SMTP_PASS (NOT your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx        # 16-char App Password from Google
FROM_NAME=Tastevo Restaurant
FROM_EMAIL=noreply@yourrestaurant.com
NOTIFY_EMAIL=owner@yourrestaurant.com  # Receives contact/reservation alerts
